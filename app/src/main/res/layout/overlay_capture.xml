<?xml version="1.0" encoding="utf-8"?>
<!-- 捕捉模式悬浮面板：只用基础控件，避免无障碍服务 context 没有 Material 主题导致 inflate 崩溃 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_overlay_panel"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/drag_handle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⠿ 咋还在刷 · 捕捉模式"
        android:textColor="#9AA4B8"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/text_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:maxWidth="230dp"
        android:textColor="#FFFFFF"
        android:textSize="11sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_positive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_overlay_button"
            android:backgroundTint="#2E7D32"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:text="✓ 短视频页"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btn_negative"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_overlay_button"
            android:backgroundTint="#C62828"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:text="✕ 非短视频"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/text_counts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="正 0 · 负 0"
        android:textColor="#9AA4B8"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_generate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_overlay_button"
            android:backgroundTint="#1565C0"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:text="生成规则"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btn_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_overlay_button"
            android:backgroundTint="#455064"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:text="关闭"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
